#!/bin/sh
set -e

cd "$(git rev-parse --show-toplevel)"

PASS=true
TEST_COMPOSE="docker compose -f docker/docker-compose.test.yml"

CHANGED_GO=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '^backend/.*\.go$' || true)
CHANGED_TS=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '^frontend/src/.*\.\(ts\|tsx\)$' || true)

if [ "$CHANGED_GO" -gt 0 ]; then
  echo "=== Checking Go code ==="
  $TEST_COMPOSE run --rm --no-deps backend-check \
    sh -c "golangci-lint run ./... && go test ./..." \
    || { echo "FAIL: Go checks"; PASS=false; }
fi

if [ "$CHANGED_TS" -gt 0 ]; then
  echo "=== Checking TypeScript ==="
  $TEST_COMPOSE run --rm --no-deps frontend-check \
    || { echo "FAIL: TypeScript check"; PASS=false; }
fi

$PASS || exit 1
